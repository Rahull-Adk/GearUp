# Database Configuration
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=gearup;Username=postgres;Password=your_password;
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=gearup

# Redis Configuration
Redis__ConnectionString=localhost:6379

# JWT Configuration
Jwt__Issuer=https://localhost:5255
Jwt__Audience=https://localhost:5255
Jwt__AccessToken_SecretKey=your_super_secret_key_minimum_32_characters_long_replace_this
Jwt__EmailVerificationToken_SecretKey=your_email_verification_secret_key_minimum_32_characters_long
Jwt__OpaqueTokenPepper=your_random_pepper_value_for_token_hashing

# Email Configuration (SendGrid)
SendGridApiKey=your_sendgrid_api_key
FromEmail=noreply@yourdomain.com

# Application Configuration
ClientUrl=http://localhost:3000
ASPNETCORE_ENVIRONMENT=Development

# Startup DB task mode
# web (default), db-migrate, db-seed, db-task (legacy alias)
APP_STARTUP_MODE=web

# Seed scope used only when startup mode runs seed tasks
# admin = only admin account, full = admin + all additional seed data
DB_SEED_SCOPE=full

# Legacy dev-only DB task flags
RUN_DB_TASKS_IN_DEVELOPMENT=false
RUN_DB_TASKS_ONCE_AND_EXIT=false

# Cloudinary Configuration
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id

# Admin Seeder Configuration
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@gearup.com
ADMIN_PASSWORD=Admin@123456

# Docker Specific (Optional)
KestrelCertificates__Development__Password=
